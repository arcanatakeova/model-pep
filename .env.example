# AI Trader — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys
# 3. Never commit .env to git

# ═══════════════════════════════════════════════════════════════
#  PHANTOM WALLET (Solana on-chain trading via Jupiter DEX)
# ═══════════════════════════════════════════════════════════════
# How to get: Phantom → Settings → Security → Export Private Key
# Paste the base58 private key here (starts with numbers/letters)
PHANTOM_PRIVATE_KEY=

# Optional: use a dedicated Solana RPC for better speed/reliability
# Free tiers: Helius (helius.dev), QuickNode, Alchemy
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ═══════════════════════════════════════════════════════════════
#  POLYMARKET (Prediction market trading on Polygon)
# ═══════════════════════════════════════════════════════════════
# This is an Ethereum-compatible private key for your Polygon wallet
# Fund with USDC on Polygon network for trading
POLYMARKET_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════════
#  CEX TRADING — BINANCE (optional)
# ═══════════════════════════════════════════════════════════════
# Spot trading only — DO NOT enable withdrawals on these keys
BINANCE_API_KEY=
BINANCE_SECRET=

# ═══════════════════════════════════════════════════════════════
#  CEX TRADING — COINBASE PRO (optional)
# ═══════════════════════════════════════════════════════════════
COINBASE_API_KEY=
COINBASE_SECRET=

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL DATA UPGRADES (bot works fine without these)
# ═══════════════════════════════════════════════════════════════
# CoinGecko Pro — removes rate limits
COINGECKO_API_KEY=

# Alpha Vantage — better stock data
ALPHAVANTAGE_KEY=

# Finnhub — real-time stock quotes
FINNHUB_KEY=
