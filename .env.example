# AI Trader — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in SUPABASE_URL + SUPABASE_SERVICE_KEY (everything else goes in Supabase)
# 3. Never commit .env to git

# ═══════════════════════════════════════════════════════════════
#  SUPABASE (secrets vault + persistence) — REQUIRED
# ═══════════════════════════════════════════════════════════════
# Get from: https://supabase.com → project → Settings → API
# Use service_role key (not anon) — keeps secrets server-side only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Once Supabase is set up, store all other keys IN Supabase (not here).
# See supabase_schema.sql for setup instructions.

# ═══════════════════════════════════════════════════════════════
#  PHANTOM WALLET (Solana on-chain trading via Jupiter DEX)
# ═══════════════════════════════════════════════════════════════
# How to get: Phantom → Settings → Security → Export Private Key
# Paste the base58 private key here (starts with numbers/letters)
PHANTOM_PRIVATE_KEY=

# Optional: use a dedicated Solana RPC for better speed/reliability
# Free tiers: Helius (helius.dev), QuickNode, Alchemy
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ═══════════════════════════════════════════════════════════════
#  POLYMARKET (Prediction market trading on Polygon)
# ═══════════════════════════════════════════════════════════════
# This is an Ethereum-compatible private key for your Polygon wallet
# Fund with USDC on Polygon network for trading
POLYMARKET_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════════
#  CEX TRADING — BINANCE (optional)
# ═══════════════════════════════════════════════════════════════
# Spot trading only — DO NOT enable withdrawals on these keys
BINANCE_API_KEY=
BINANCE_SECRET=

# ═══════════════════════════════════════════════════════════════
#  CEX TRADING — COINBASE ADVANCED TRADE (optional)
# ═══════════════════════════════════════════════════════════════
# CDP (new) auth: key name = organizations/xxx/apiKeys/yyy
#                 secret   = EC private key (PEM, paste with literal \n)
COINBASE_KEY_NAME=
COINBASE_SECRET=
# Legacy key (old Coinbase Pro / Advanced Trade legacy):
COINBASE_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  REAL-TIME SOLANA DATA — BIRDEYE (strongly recommended)
# ═══════════════════════════════════════════════════════════════
# Get key at https://birdeye.so — Starter plan (~$99/mo)
# Used for: real-time token prices, OHLCV, holder data, trending tokens
BIRDEYE_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL DATA UPGRADES (bot works fine without these)
# ═══════════════════════════════════════════════════════════════
# CoinGecko Pro — removes rate limits on crypto data
COINGECKO_API_KEY=

# Alpha Vantage — forex OHLCV (needed if FOREX_ENABLED=True)
ALPHAVANTAGE_KEY=

# Finnhub — real-time stock quotes + OHLCV (replaces yfinance)
FINNHUB_KEY=
