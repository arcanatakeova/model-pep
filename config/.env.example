# ARCANA AI — Environment Variables
# Copy to .env and fill in your keys. NEVER commit .env to git.

# === LLM ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === Market Data ===
BIRDEYE_API_KEY=your-birdeye-key
UNUSUAL_WHALES_API_KEY=your-uw-key
FINNHUB_API_KEY=your-finnhub-key
# DexScreener: No key needed
# Rugcheck: No key needed (public API)

# === Trading — Solana ===
SOLANA_PRIVATE_KEY=your-burner-wallet-base58-private-key
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-key
# CRITICAL: Use a DEDICATED BURNER WALLET. Fund with ONLY trading capital.

# === Trading — Polymarket ===
POLYMARKET_PRIVATE_KEY=your-polygon-wallet-private-key
# Polymarket operates on Polygon. Separate wallet from Solana.

# === Trading — Coinbase ===
COINBASE_API_KEY=your-coinbase-key
COINBASE_API_SECRET=your-coinbase-secret

# === Social — X/Twitter ===
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_SECRET=your-x-access-token-secret
# Basic tier: $200/month. 15K reads, 50K writes per month.

# === Content Production ===
HEYGEN_API_KEY=your-heygen-key
MAKEUGC_API_KEY=your-makeugc-key
ELEVENLABS_API_KEY=your-elevenlabs-key

# === Payments ===
STRIPE_SECRET_KEY=sk_live_your-stripe-key
GUMROAD_ACCESS_TOKEN=your-gumroad-token

# === Database ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# === Notifications ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === Optional ===
KEEPA_API_KEY=your-keepa-key
DEEPL_API_KEY=your-deepl-key
BEEHIIV_API_KEY=your-beehiiv-key

# === Agent Config ===
DRY_RUN=true
# Set to false when ready for live trading. Start with true.
TRADING_CAPITAL=1000
MAX_POSITION_PCT=5
STOP_LOSS_PCT=15
DAILY_DRAWDOWN_LIMIT_PCT=10
ORCHESTRATOR_INTERVAL_MINUTES=15
