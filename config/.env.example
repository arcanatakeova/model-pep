# ARCANA AI — Environment Variables
# Copy to config/.env and fill in your keys. NEVER commit .env to git.
# UNLIMITED ACCESS — every API that makes money gets a key.

# === LLM (OpenRouter — required) ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === X / Twitter (required — $200/mo Basic tier) ===
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_SECRET=your-x-access-token-secret

# === Payments ===
STRIPE_SECRET_KEY=sk_live_your-stripe-key
GUMROAD_ACCESS_TOKEN=your-gumroad-token

# === Notifications (Ian & Tan) ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === iMessage via Sendblue (https://sendblue.co) ===
SENDBLUE_API_KEY=your-sendblue-api-key
SENDBLUE_API_SECRET=your-sendblue-api-secret
IMESSAGE_IAN_NUMBER=+1XXXXXXXXXX
IMESSAGE_TAN_NUMBER=+1XXXXXXXXXX

# === Newsletter (Beehiiv) ===
BEEHIIV_API_KEY=your-beehiiv-key
BEEHIIV_PUBLICATION_ID=your-publication-id

# === Content / UGC Video Production ===
HEYGEN_API_KEY=your-heygen-key
MAKEUGC_API_KEY=your-makeugc-key
ELEVENLABS_API_KEY=your-elevenlabs-key

# === SEO / Publishing ===
VERCEL_TOKEN=your-vercel-token
GOOGLE_ADSENSE_ID=ca-pub-your-id

# === Email (SendGrid) ===
SENDGRID_API_KEY=your-sendgrid-key

# === Lead Gen / Outreach ===
APOLLO_API_KEY=your-apollo-key
INSTANTLY_API_KEY=your-instantly-key

# === LinkedIn ===
LINKEDIN_TOKEN=your-linkedin-oauth-token

# === Social Media Management ===
BUFFER_API_KEY=your-buffer-key

# === Review Platforms ===
GOOGLE_BUSINESS_TOKEN=your-google-business-token

# === Deal Monitoring ===
KEEPA_API_KEY=your-keepa-key
AMAZON_PA_KEY=your-amazon-pa-key
AMAZON_PA_SECRET=your-amazon-pa-secret

# === Translation ===
DEEPL_API_KEY=your-deepl-key

# === Agent Config ===
DRY_RUN=true
# Set to false when ready for live operations. Start with true.
